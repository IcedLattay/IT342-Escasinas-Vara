<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".auth.LoginActivity">

    <LinearLayout
        android:id="@+id/vara_icon_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"

        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="30dp">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/vara_logo"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:text="Vara"
            android:fontFamily="@font/inter"
            android:textFontWeight="700"
            android:textSize="20sp"

            android:layout_marginStart="5dp"/>

    </LinearLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/body"
        android:layout_width="match_parent"
        android:layout_height="match_parent"

        app:layout_constraintTop_toBottomOf="@+id/vara_icon_label"
        android:layout_marginTop="150dp">

        <LinearLayout
            android:id="@+id/top"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"

            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"

                android:text="Login to your\naccount"
                android:fontFamily="@font/inter"
                android:textFontWeight="700"
                android:textSize="32sp"
                android:lineHeight="35dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"

                android:layout_marginTop="30dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"

                    android:text="Email Address"
                    android:fontFamily="@font/inter"
                    android:textSize="14sp"
                    android:textFontWeight="500"/>

                <EditText
                    android:id="@+id/emailAddress_editText"

                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"

                    android:paddingVertical="12dp"
                    android:paddingHorizontal="10dp"

                    android:fontFamily="@font/inter"
                    android:hint="Enter your email"
                    android:background="@drawable/input_field_bg"
                    android:textSize="14sp"

                    android:layout_marginTop="5dp"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"

                android:layout_marginTop="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"

                    android:text="Password"
                    android:fontFamily="@font/inter"
                    android:textSize="14sp"
                    android:textFontWeight="500"/>

                <EditText
                    android:id="@+id/password_editText"

                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"

                    android:paddingVertical="12dp"
                    android:paddingHorizontal="10dp"

                    android:fontFamily="@font/inter"
                    android:inputType="textPassword"
                    android:hint="Enter your password"
                    android:background="@drawable/input_field_bg"
                    android:textSize="14sp"

                    android:layout_marginTop="5dp"/>

            </LinearLayout>

            <TextView
                android:id="@+id/nonFieldError_text"

                android:layout_width="wrap_content"
                android:layout_height="wrap_content"

                android:text="Email and password are incorrect."
                android:textColor="@color/error_red"
                android:fontFamily="@font/inter"
                android:textSize="14sp"
                android:textFontWeight="400"
                android:visibility="gone"

                android:layout_marginTop="10dp"/>

            <TextView
                android:id="@+id/forgotPassword_button"

                android:layout_width="wrap_content"
                android:layout_height="wrap_content"

                android:text="Forgot Password?"
                android:fontFamily="@font/inter"
                android:textFontWeight="900"
                android:textSize="14sp"

                android:layout_marginTop="10dp"/>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/bottom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"

            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginBottom="20dp">

            <TextView
                android:id="@+id/goToRegister_button"

                android:layout_width="wrap_content"
                android:layout_height="wrap_content"

                android:text="Don't have an account?"
                android:fontFamily="@font/inter"
                android:textFontWeight="900"
                android:textSize="14sp"

                android:layout_gravity="center_horizontal"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"

                android:layout_marginTop="15dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/continueWithGoogle_button"

                    android:layout_width="match_parent"
                    android:layout_height="56dp"

                    android:text="Continue with Google"
                    android:textColor="#000000"
                    android:fontFamily="@font/inter"
                    android:textFontWeight="500"
                    android:textSize="14sp"

                    app:backgroundTint="#E9E9E9"
                    app:icon="@drawable/google_icon"
                    app:iconTint="@null"
                    app:iconSize="20sp"
                    app:iconGravity="textEnd"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/login_button"

                    android:layout_width="match_parent"
                    android:layout_height="56dp"

                    android:text="Login"
                    android:textColor="@color/button_text"
                    android:fontFamily="@font/inter"
                    android:textFontWeight="900"
                    android:textSize="14sp"

                    app:backgroundTint="@color/button_bg"

                    android:layout_marginTop="5dp"

                    android:enabled="false"/>

            </LinearLayout>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>


</androidx.constraintlayout.widget.ConstraintLayout>