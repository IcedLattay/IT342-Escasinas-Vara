<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".auth.LoginActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"

        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

                <LinearLayout
                    android:id="@+id/vara_icon_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"

                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:layout_marginTop="30dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/vara_logo"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"

                        android:text="Vara"
                        android:fontFamily="@font/inter"
                        android:textFontWeight="700"
                        android:textSize="20sp"

                        android:layout_marginStart="5dp"/>

                </LinearLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/body"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"

                    app:layout_constraintTop_toBottomOf="@+id/vara_icon_label"
                    android:layout_marginTop="100dp">

                    <LinearLayout
                        android:id="@+id/top"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="20dp"

                        app:layout_constraintTop_toTopOf="parent">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"

                            android:text="Create your account"
                            android:fontFamily="@font/inter"
                            android:textFontWeight="700"
                            android:textSize="32sp"
                            android:lineHeight="35dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"

                            android:layout_marginTop="30dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"

                                android:text="First Name"
                                android:fontFamily="@font/inter"
                                android:textSize="14sp"
                                android:textFontWeight="500"/>

                            <EditText
                                android:id="@+id/firstname_editText"

                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"

                                android:paddingVertical="14dp"
                                android:paddingHorizontal="10dp"

                                android:fontFamily="@font/inter"
                                android:hint="Enter your first name"
                                android:textColorHint="#8C8C8C"
                                android:background="@drawable/input_field_bg"
                                android:textSize="14sp"

                                android:layout_marginTop="5dp"/>

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"

                            android:layout_marginTop="10dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"

                                android:text="Last Name"
                                android:fontFamily="@font/inter"
                                android:textSize="14sp"
                                android:textFontWeight="500"/>

                            <EditText
                                android:id="@+id/lastname_editText"

                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"

                                android:paddingVertical="14dp"
                                android:paddingHorizontal="10dp"

                                android:fontFamily="@font/inter"
                                android:hint="Enter your last name"
                                android:textColorHint="#8C8C8C"
                                android:background="@drawable/input_field_bg"
                                android:textSize="14sp"

                                android:layout_marginTop="5dp"/>

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"

                            android:layout_marginTop="10dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"

                                android:text="Email Address"
                                android:fontFamily="@font/inter"
                                android:textSize="14sp"
                                android:textFontWeight="500"/>

                            <EditText
                                android:id="@+id/emailAddress_editText"

                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"

                                android:paddingVertical="14dp"
                                android:paddingHorizontal="10dp"

                                android:fontFamily="@font/inter"
                                android:hint="Enter your email"
                                android:textColorHint="#8C8C8C"
                                android:background="@drawable/input_field_bg"
                                android:textSize="14sp"

                                android:layout_marginTop="5dp"/>

                            <TextView
                                android:id="@+id/emailAddressError_text"

                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"

                                android:text=""
                                android:textColor="@color/error_red"
                                android:fontFamily="@font/inter"
                                android:textSize="14sp"
                                android:textFontWeight="400"

                                android:layout_marginTop="5dp"

                                android:visibility="gone"/>

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"

                            android:layout_marginTop="10dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"

                                android:text="Password"
                                android:fontFamily="@font/inter"
                                android:textSize="14sp"
                                android:textFontWeight="500"/>

                            <EditText
                                android:id="@+id/password_editText"

                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"

                                android:paddingVertical="14dp"
                                android:paddingHorizontal="10dp"

                                android:fontFamily="@font/inter"
                                android:inputType="textPassword"
                                android:hint="Enter your password"
                                android:textColorHint="#8C8C8C"
                                android:background="@drawable/input_field_bg"
                                android:textSize="14sp"

                                android:layout_marginTop="5dp"/>

                            <LinearLayout

                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"

                                android:layout_marginTop="5dp">

                                <TextView
                                    android:id="@+id/passwordError_text"

                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"

                                    android:text="Email already exists."
                                    android:textColor="@color/error_red"
                                    android:fontFamily="@font/inter"
                                    android:textSize="14sp"
                                    android:textFontWeight="400"

                                    android:visibility="gone"/>

                                <LinearLayout
                                    android:id="@+id/passwordRules_container"

                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"

                                    android:visibility="gone">

                                    <TextView
                                        android:id="@+id/firstRule_text"

                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"

                                        android:text="At least 8 characters"
                                        android:fontFamily="@font/inter"
                                        android:textSize="14sp"
                                        android:textFontWeight="400"/>

                                    <TextView
                                        android:id="@+id/secondRule_text"

                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"

                                        android:text="Contains an uppercase and lowercase letter"
                                        android:fontFamily="@font/inter"
                                        android:textSize="14sp"
                                        android:textFontWeight="400"/>

                                    <TextView
                                        android:id="@+id/thirdRule_text"

                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"

                                        android:text="Contains a number"
                                        android:fontFamily="@font/inter"
                                        android:textSize="14sp"
                                        android:textFontWeight="400"/>

                                </LinearLayout>

                            </LinearLayout>

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"

                            android:layout_marginTop="10dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"

                                android:text="Confirm Password"
                                android:fontFamily="@font/inter"
                                android:textSize="14sp"
                                android:textFontWeight="500"/>

                            <EditText
                                android:id="@+id/confirmPassword_editText"

                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"

                                android:paddingVertical="14dp"
                                android:paddingHorizontal="10dp"

                                android:fontFamily="@font/inter"
                                android:inputType="textPassword"
                                android:hint="Confirm your password"
                                android:textColorHint="#8C8C8C"
                                android:background="@drawable/input_field_bg"
                                android:textSize="14sp"

                                android:layout_marginTop="5dp"/>

                            <TextView
                                android:id="@+id/confirmPasswordError_text"

                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"

                                android:text=""
                                android:textColor="@color/error_red"
                                android:fontFamily="@font/inter"
                                android:textSize="14sp"
                                android:textFontWeight="400"
                                android:visibility="gone"

                                android:layout_marginTop="5dp"/>

                        </LinearLayout>

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/bottom"

                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="20dp"

                        app:layout_constraintTop_toBottomOf="@id/top"
                        android:layout_marginTop="50dp">

                        <TextView
                            android:id="@+id/goToLogin_button"

                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"

                            android:text="Already have an account?"
                            android:fontFamily="@font/inter"
                            android:textFontWeight="900"
                            android:textSize="14sp"

                            android:layout_gravity="center_horizontal"/>

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/createAccount_button"

                                android:layout_width="match_parent"
                                android:layout_height="56dp"

                                android:text="Create account"
                                android:textColor="@color/button_text"
                                android:fontFamily="@font/inter"
                                android:textFontWeight="900"
                                android:textSize="14sp"

                                app:backgroundTint="@color/button_bg"

                                android:layout_marginTop="15dp"
                                android:layout_marginBottom="30dp"

                                android:enabled="false"/>


                    </LinearLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>